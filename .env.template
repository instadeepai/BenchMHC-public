# Logs' parameters
LOG_BACKUP_COUNT=50
LOG_DIRECTORY=${PWD}/.logs/
LOG_LEVEL=INFO

# MLflow (experiment tracking)
MLFLOW_WORKSPACE=my-workspace
MLFLOW_EXPERIMENT_NAME=my-experiment
# Local server:
MLFLOW_TRACKING_URI=http://localhost:5000
# File-based (no server):
# MLFLOW_TRACKING_URI=data/mlflow_logs
# Remote server:
# MLFLOW_TRACKING_URI=https://<your-remote-server>/
# MLFLOW_TRACKING_USERNAME=your.name@instadeep.com
# MLFLOW_TRACKING_PASSWORD=<personal-access-token>
